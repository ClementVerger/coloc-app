# ============================================================
# Variables d'environnement — Production (Railway / Render)
# ============================================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer le fichier .env dans git.

# --- Serveur ---
NODE_ENV=production
# PORT est injecté automatiquement par Railway/Render — ne pas définir manuellement.
# PORT=3000

# --- Base de données ---
# Injecté automatiquement par Railway (plugin PostgreSQL) ou Render (service DB lié).
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@host:5432/coloc_db

# --- Clerk (Auth) ---
# Récupérer sur https://dashboard.clerk.com > Votre app > API Keys
# Utiliser les clés de PRODUCTION (préfixe sk_live_ / pk_live_), pas les clés de test.
CLERK_SECRET_KEY=sk_live_...

# --- CORS ---
# Pour une app React Native (iOS/Android pure), ce champ est IGNORÉ :
# les apps natives n'envoient pas d'en-tête Origin, le mécanisme CORS ne s'applique pas.
# À renseigner uniquement si vous ajoutez un frontend web.
# Exemple : ALLOWED_ORIGINS=https://coloc-app.vercel.app
ALLOWED_ORIGINS=*

# --- Mindee v2 (OCR tickets de caisse) ---
# Récupérer sur https://app.mindee.com > Settings > API Keys
MINDEE_API_KEY=
MINDEE_OCR_MODEL_ID=9fda0748-bfac-4637-ae65-dea08ea10a18
