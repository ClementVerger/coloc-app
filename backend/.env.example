PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/coloc_db

# Auth (Clerk) — récupérer sur https://dashboard.clerk.com > Votre app > API Keys
CLERK_SECRET_KEY=sk_test_...

# CORS
ALLOWED_ORIGINS=http://localhost:8081

# OCR Tickets de caisse (Mindee v2) — récupérer sur https://app.mindee.com > Settings > API Keys
MINDEE_API_KEY=
# ID du modèle OCR Mindee v2 (optionnel, défaut = modèle OCR générique)
MINDEE_OCR_MODEL_ID=9fda0748-bfac-4637-ae65-dea08ea10a18
